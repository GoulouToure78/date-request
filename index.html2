<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Emel — Selection</title>
<style>
body { margin: 0; background: black; color: white; font-family: 'Georgia', serif; overflow: hidden; }
.screen { position: relative; z-index: 2; height: 100vh; display: flex; justify-content: center; align-items: center; flex-direction: column; text-align: center; padding: 20px; }
.bg {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  object-position: center top;
  opacity: 0.55;
  filter: brightness(0.6) contrast(1.2);
  z-index: 1;
}
.bg-intro {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  object-position: center top;
  opacity: 0.9;
  filter: grayscale(1) contrast(1.15) brightness(0.65);
  z-index: 1;
}
#intro-overlay {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: linear-gradient(to bottom, rgba(100,0,0,0.15) 0%, rgba(0,0,0,0.6) 100%);
  z-index: 2;
  pointer-events: none;
}
/* Bandes cinéma letterbox */
body::before, body::after {
  content: '';
  position: fixed;
  left: 0; right: 0;
  height: 13vh;
  background: black;
  z-index: 10;
  pointer-events: none;
}
body::before { top: 0; }
body::after { bottom: 0; }
h1 { font-size: 3em; letter-spacing: 3px; }
h2 { font-weight: 300; max-width: 600px; line-height: 1.4; }
.gold { color: #d4af37; }
button { margin: 15px; padding: 14px 28px; border-radius: 30px; border: none; font-size: 16px; cursor: pointer; }
#yes { background: #d4af37; color: black; }
#no { background: #333; color: white; position: relative; }
.choice-btn {
  background: #1a1a1a;
  color: white;
  border: 1px solid #444;
  border-radius: 10px;
  padding: 14px 28px;
  font-size: 15px;
  font-family: Georgia, serif;
  cursor: pointer;
  transition: all 0.2s;
  min-width: 130px;
}
.choice-btn:hover { border-color: #d4af37; }
#restart { position: fixed; bottom: 20px; right: 20px; background: rgba(255,255,255,0.15); color: white; border: 1px solid rgba(255,255,255,0.3); font-size: 13px; padding: 8px 18px; border-radius: 20px; cursor: pointer; z-index: 999; backdrop-filter: blur(4px); margin-bottom: 13vh; }
.screen { z-index: 20 !important; }
.fade { animation: fade 1s ease; }
@keyframes fade { from {opacity: 0;} to {opacity: 1;} }
/* Code pour modifier la taille des images des looks */
.look-img {
  max-height: 75vh !important; /* Hauteur maximale de l'image (65% de l'écran) */
  max-width: 100vw !important;  /* Largeur maximale de l'image (90% de l'écran) */
  object-fit: contain !important; /* Conserve les proportions sans déformer */
  margin-bottom: 20px;
  border-radius: 8px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.5);
}
</style>
</head>
<body>

<div id="intro-overlay"></div>
<button id="restart" onclick="location.reload()" style="display:none">↺ Restart</button>
<div id="app" class="screen" id="intro">
  <img class="bg-intro" src="images/PA2.jpg">
  <div id="winx-text" style="
    position: relative;
    z-index: 20;
    text-align: center;
    margin-top: auto;
    margin-bottom: 16vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  ">
    <p style="
      font-family: 'Georgia', serif;
      font-size: 0.55em;
      letter-spacing: 8px;
      text-transform: uppercase;
      color: #555;
      margin: 0 0 16px 0;
      animation: introPulse 3s ease-in-out infinite;
    ">— Tap to enter —</p>
    <div style="width:30px;height:1px;background:#8b0000;margin:0 auto 16px auto;"></div>
    <p style="
      font-family: 'Georgia', serif;
      font-size: 2.2em;
      font-weight: 400;
      font-style: italic;
      letter-spacing: 8px;
      color: #fff;
      margin: 0 0 6px 0;
      text-shadow: 0 0 40px rgba(139,0,0,0.4);
      animation: introPulse 3s ease-in-out infinite;
    ">Emel's World</p>
  </div>
</div>

<style>
@keyframes introPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}
</style>

<audio id="music" preload="auto">
  <source src="music.mp3" type="audio/mpeg">
</audio>

<script>
let app = document.getElementById("app");

const screens = [
  { text: "In a world... where elegance is everything...", img: "data:image/jpeg;base64," },
  { text: "Where style defines power...", img: "images/Alaia WS26 look front_035.jpg" },
  { text: "One woman stands above the rest...", img: "data:image/jpeg;base64," },
  { text: "Emel", img: "images/Alaia W26 look detail_18_034.jpg" },
  { text: "Style. Grace. Power.", img: "data:image/jpeg;base64,"}
];

let i = 0;

function playVoiceAndWait(text, callback) {
  window.speechSynthesis.cancel();
  const speech = new SpeechSynthesisUtterance(text);
  speech.lang = "en-US";
  speech.rate = 0.85;
  speech.pitch = 0.9;

  let called = false;
  const done = () => { if (!called) { called = true; setTimeout(callback, 600); } };

  speech.onend = done;
  const estimatedDuration = (text.length / 12) * 1000 + 1500;
  setTimeout(done, estimatedDuration);

  window.speechSynthesis.speak(speech);
}

function next() {
  const ov = document.getElementById('intro-overlay'); if(ov) ov.style.display='none';
  if (i < screens.length) {
    const current = screens[i];
    i++;
    app.innerHTML = `<img class="bg" src="${current.img}"><h2 class="fade">${current.text}</h2>`;
    playVoiceAndWait(current.text, next);
  } else {
    finalScreen();
  }
}

function finalScreen() {
  app.style.cssText = "display:flex;justify-content:center;align-items:center;flex-direction:column;height:100vh;z-index:20;position:relative;text-align:center;padding:40px 20px;";
  app.innerHTML = `
    <div class="fade" style="display:flex;flex-direction:column;align-items:center;width:100%;max-width:420px;gap:0;">
      <p style="
        font-family:'Georgia',serif;
        font-size:0.55em;
        letter-spacing:8px;
        text-transform:uppercase;
        color:#555;
        margin:0 0 20px 0;
      ">— An Invitation —</p>

      <div style="width:40px;height:1px;background:#8b0000;margin:0 auto 28px auto;"></div>

      <h1 style="
        font-family:'Georgia',serif;
        font-size:3.2em;
        font-weight:400;
        font-style:italic;
        letter-spacing:6px;
        color:#fff;
        margin:0 0 8px 0;
        line-height:1;
      ">Emel</h1>

      <p style="
        font-family:'Georgia',serif;
        font-size:0.75em;
        letter-spacing:4px;
        text-transform:uppercase;
        color:#888;
        margin:0 0 40px 0;
        font-style:normal;
      ">will you go on a date with me ?</p>

      <div style="width:100%;height:1px;background:#1a1a1a;margin-bottom:40px;"></div>

      <div style="display:flex;flex-direction:column;gap:14px;width:100%;">
        <button id="yes" style="
          background:transparent;
          color:#fff;
          border:1px solid #8b0000;
          border-radius:0;
          padding:18px 0;
          font-family:'Georgia',serif;
          font-size:0.75em;
          letter-spacing:7px;
          text-transform:uppercase;
          cursor:pointer;
          width:100%;
          transition:all 0.4s;
        ">Yes</button>

        <button id="no" style="
          background:transparent;
          color:#444;
          border:none;
          border-bottom:1px solid #222;
          border-radius:0;
          padding:14px 0;
          font-family:'Georgia',serif;
          font-size:0.65em;
          letter-spacing:5px;
          text-transform:uppercase;
          cursor:pointer;
          width:100%;
          position:relative;
          transition:all 0.3s;
        ">No</button>
      </div>
    </div>
  `;

  window.speechSynthesis.cancel();
  const speech = new SpeechSynthesisUtterance("Emel... will you go on a date with me?");
  speech.lang = "en-US";
  speech.rate = 0.85;
  speech.pitch = 0.9;
  window.speechSynthesis.speak(speech);

  const noBtn = document.getElementById("no");
  const moveNoBtn = () => {
    noBtn.style.position = "fixed";
    noBtn.style.left = Math.max(10, Math.min(Math.random() * (window.innerWidth - 120), window.innerWidth - 130)) + "px";
    noBtn.style.top = Math.max(10, Math.min(Math.random() * (window.innerHeight - 60), window.innerHeight - 70)) + "px";
  };
  noBtn.addEventListener("mouseover", moveNoBtn);
  noBtn.addEventListener("touchstart", (e) => { e.preventDefault(); moveNoBtn(); });
  noBtn.addEventListener("click", (e) => { e.preventDefault(); moveNoBtn(); });

  document.getElementById("yes").onclick = () => startGame();
}

// ── JEU : TROUVER L'INTRUS ──
const fashionRounds = [
  {
    house: "Alaia",
    looks: [
      "images/Alaia W26 look detail_35_064.jpg",
      "images/Alaia W26 look detail_23_041.jpg",
      "images/le-defile-alaia-ete-automne-2025-fashion-week-paris-13.jpg",
      "images/Alaia WS26 look front_013.jpg",
    ],
    intruder: "images/fendi.avif",
    intruderHouse: "Coperni"
  },
  {
    house: "Bottega Veneta",
    looks: [
      "images/le-defile-bottega-veneta-printemps-ete-2025-fashion-week-de-milan18.jpg",
      "images/le-defile-bottega-veneta-printemps-ete-2025-fashion-week-de-milan3.jpg",
      "images/Large-FIO00311.avif",
      "images/le-defile-bottega-veneta-printemps-ete-2025-fashion-week-de-milan19.jpg",
    ],
    intruder: "images/le-defile-coperni-automne-hiver-2025-20269.jpg",
    intruderHouse: "Coperni"
  }
];

let gameRound = 0;
let gameLives = 5;
let intruderIndex = 0;

function startGame() {
  gameRound = 0;
  gameLives = 5;
  showGameRound();
}

function showGameRound() {
  const round = fashionRounds[gameRound % fashionRounds.length];
  // Placer l'intrus à une position aléatoire parmi 5 images
  const allLooks = [...round.looks];
  intruderIndex = Math.floor(Math.random() * 5);
  allLooks.splice(intruderIndex, 0, round.intruder);
  const items = allLooks.slice(0, 5);

  const heartsHTML = '♥'.repeat(gameLives) + '<span style="color:#333">' + '♥'.repeat(5 - gameLives) + '</span>';

  const appEl = document.getElementById("app");
  appEl.style.cssText = "display:flex;justify-content:center;align-items:center;flex-direction:column;height:100vh;z-index:20;position:relative;text-align:center;padding:20px 10px;";
  appEl.innerHTML = `
    <div class="fade" style="display:flex;flex-direction:column;align-items:center;width:100%;max-width:520px;gap:0;">
      <p style="font-family:'Georgia',serif;font-size:0.55em;letter-spacing:8px;text-transform:uppercase;color:#555;margin:0 0 10px 0;">— The Game —</p>
      <div style="width:40px;height:1px;background:#8b0000;margin:0 auto 16px auto;"></div>
      <h2 style="font-family:'Georgia',serif;font-size:1em;font-weight:400;letter-spacing:4px;text-transform:uppercase;color:#fff;margin:0 0 6px 0;">Find the intruder</h2>
      <p style="font-family:'Georgia',serif;font-size:0.6em;letter-spacing:3px;color:#666;margin:0 0 16px 0;text-transform:uppercase;">All looks are ${round.house} — except one</p>
      <p style="font-size:1.1em;letter-spacing:3px;color:#8b0000;margin:0 0 18px 0;">${heartsHTML}</p>
      <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:6px;width:100%;">
        ${items.map((src, idx) => `
          <div onclick="checkAnswer(${idx})" style="
            cursor:pointer;
            overflow:hidden;
            aspect-ratio:2/3;
            border:1px solid #1a1a1a;
            transition:border 0.2s;
          " onmouseover="this.style.borderColor='#8b0000'" onmouseout="this.style.borderColor='#1a1a1a'">
            <img src="${src}" style="width:100%;height:100%;object-fit:cover;object-position:top;" onerror="this.parentElement.style.background='#111'">
          </div>
        `).join('')}
      </div>
      <p style="font-family:'Georgia',serif;font-size:0.55em;letter-spacing:4px;text-transform:uppercase;color:#333;margin:16px 0 0 0;">${5 - gameLives} mistake${5-gameLives !== 1 ? 's' : ''} — ${gameLives} chance${gameLives !== 1 ? 's' : ''} left</p>
    </div>
  `;
}

function checkAnswer(idx) {
  if (idx === intruderIndex) {
    // BONNE RÉPONSE
    gameRound++;
    if (gameRound >= 2) {
      showVictory();
    } else {
      showFeedback(true, () => showGameRound());
    }
  } else {
    // MAUVAISE RÉPONSE
    gameLives--;
    if (gameLives <= 0) {
      showDefeat();
    } else {
      showFeedback(false, () => showGameRound());
    }
  }
}

function showFeedback(correct, cb) {
  const appEl = document.getElementById("app");
  const msg = correct
    ? `<p style="color:#fff;font-family:'Georgia',serif;font-size:1em;letter-spacing:4px;text-transform:uppercase;">✓ Correct</p><p style="color:#555;font-size:0.65em;letter-spacing:3px;font-family:'Georgia',serif;">Round 2 — one more</p>`
    : `<p style="color:#8b0000;font-family:'Georgia',serif;font-size:1em;letter-spacing:4px;text-transform:uppercase;">✗ Wrong</p><p style="color:#555;font-size:0.65em;letter-spacing:3px;font-family:'Georgia',serif;">${gameLives} chance${gameLives !== 1 ? 's' : ''} remaining</p>`;
  appEl.innerHTML = `<div class="fade" style="display:flex;flex-direction:column;align-items:center;gap:16px;">${msg}</div>`;
  setTimeout(cb, 1400);
}

function showVictory() {
  const appEl = document.getElementById("app");
  appEl.style.cssText = "display:flex;justify-content:center;align-items:center;flex-direction:column;height:100vh;z-index:20;position:relative;text-align:center;padding:40px 20px;";
  appEl.innerHTML = `
    <div class="fade" style="display:flex;flex-direction:column;align-items:center;width:100%;max-width:420px;gap:0;">
      <p style="font-family:'Georgia',serif;font-size:0.55em;letter-spacing:8px;text-transform:uppercase;color:#555;margin:0 0 20px 0;">— You won —</p>
      <div style="width:40px;height:1px;background:#8b0000;margin:0 auto 24px auto;"></div>
      <h1 style="font-family:'Georgia',serif;font-size:2.4em;font-weight:400;font-style:italic;letter-spacing:4px;color:#fff;margin:0 0 8px 0;">Okay girl </h1>
      <p style="font-family:'Georgia',serif;font-size:0.7em;letter-spacing:4px;text-transform:uppercase;color:#888;margin:0 0 36px 0;">You have the eye of a fashion editor</p>
      <div style="width:100%;height:1px;background:#1a1a1a;margin-bottom:36px;"></div>
      <button onclick="showDateSelection()" style="
        background:transparent;color:#fff;border:1px solid #8b0000;border-radius:0;
        padding:18px 0;font-family:'Georgia',serif;font-size:0.75em;
        letter-spacing:7px;text-transform:uppercase;cursor:pointer;width:100%;transition:all 0.4s;
      ">Choose your evening →</button>
    </div>
  `;
}

function showDefeat() {
  const appEl = document.getElementById("app");
  appEl.style.cssText = "display:flex;justify-content:center;align-items:center;flex-direction:column;height:100vh;z-index:20;position:relative;text-align:center;padding:40px 20px;";
  appEl.innerHTML = `
    <div class="fade" style="display:flex;flex-direction:column;align-items:center;width:100%;max-width:420px;gap:0;">
      <p style="font-family:'Georgia',serif;font-size:0.55em;letter-spacing:8px;text-transform:uppercase;color:#555;margin:0 0 20px 0;">— Game over —</p>
      <div style="width:40px;height:1px;background:#8b0000;margin:0 auto 24px auto;"></div>
      <h1 style="font-family:'Georgia',serif;font-size:2em;font-weight:400;font-style:italic;letter-spacing:4px;color:#8b0000;margin:0 0 8px 0;">Not this time</h1>
      <p style="font-family:'Georgia',serif;font-size:0.7em;letter-spacing:4px;text-transform:uppercase;color:#555;margin:0 0 36px 0;">Even the greatest editors miss sometimes</p>
      <div style="width:100%;height:1px;background:#1a1a1a;margin-bottom:36px;"></div>
      <button onclick="startGame()" style="
        background:transparent;color:#fff;border:1px solid #333;border-radius:0;
        padding:18px 0;font-family:'Georgia',serif;font-size:0.75em;
        letter-spacing:7px;text-transform:uppercase;cursor:pointer;width:100%;
      ">Try again</button>
    </div>
  `;
}

function showDateSelection() {
  const appEl = document.getElementById("app");
  appEl.style.cssText = "display:flex;justify-content:center;align-items:center;flex-direction:column;height:100vh;z-index:20;position:relative;text-align:center;padding:20px;";
  appEl.innerHTML = `
    <div class="fade" style="display:flex;flex-direction:column;align-items:center;gap:0;width:100%;max-width:480px;">
      <p style="font-family:'Georgia',serif;font-size:0.65em;letter-spacing:6px;text-transform:uppercase;color:#888;margin:0 0 6px 0;">— The Selection —</p>
      <h2 style="font-family:'Georgia',serif;font-size:1.6em;font-weight:400;letter-spacing:4px;text-transform:uppercase;color:#fff;margin:0 0 32px 0;">Choose your evening</h2>
      <div style="display:flex;flex-direction:column;gap:10px;width:100%;">
        <button class="choice-btn" onclick="selectChoice('Restaurant', this)" style="background:transparent;color:#ccc;border:none;border-bottom:1px solid #333;border-radius:0;padding:18px 0;font-family:'Georgia',serif;font-size:0.85em;letter-spacing:5px;text-transform:uppercase;cursor:pointer;text-align:left;transition:all 0.3s;width:100%;">Restaurant</button>
        <button class="choice-btn" onclick="selectChoice('movie', this)" style="background:transparent;color:#ccc;border:none;border-bottom:1px solid #333;border-radius:0;padding:18px 0;font-family:'Georgia',serif;font-size:0.85em;letter-spacing:5px;text-transform:uppercase;cursor:pointer;text-align:left;transition:all 0.3s;width:100%;">movie</button>
        <button class="choice-btn" onclick="selectChoice('Ride', this)" style="background:transparent;color:#ccc;border:none;border-bottom:1px solid #333;border-radius:0;padding:18px 0;font-family:'Georgia',serif;font-size:0.85em;letter-spacing:5px;text-transform:uppercase;cursor:pointer;text-align:left;transition:all 0.3s;width:100%;">Ride</button>
      </div>
      <div style="margin-top:36px;width:100%;">
        <p style="font-family:'Georgia',serif;font-size:0.6em;letter-spacing:5px;text-transform:uppercase;color:#666;margin:0 0 10px 0;text-align:left;">Date</p>
        <input type="date" id="datepicker" onchange="checkConfirm()" style="background:transparent;color:#fff;border:none;border-bottom:1px solid #555;border-radius:0;padding:12px 0;font-size:0.9em;font-family:'Georgia',serif;letter-spacing:2px;outline:none;cursor:pointer;width:100%;color-scheme:dark;">
      </div>
      <button id="confirm-btn" onclick="confirmDate()" style="margin-top:40px;background:transparent;color:#fff;border:1px solid #fff;border-radius:0;padding:16px 60px;font-family:'Georgia',serif;font-size:0.7em;letter-spacing:6px;text-transform:uppercase;cursor:pointer;opacity:0.25;pointer-events:none;transition:all 0.4s;">Confirm</button>
    </div>
  `;
}

function restartAnimation() {
  i = 0;
  window.speechSynthesis.cancel();
  const music = document.getElementById("music");
  music.currentTime = 0;
  music.volume = 0;
  music.play().then(() => {
    let vol = 0;
    const fade = setInterval(() => {
      if (vol < 0.5) { vol += 0.05; music.volume = vol; }
      else clearInterval(fade);
    }, 200);
  }).catch(err => console.log(err));
  next();
}

let selectedChoice = null;

function selectChoice(choice, btn) {
  selectedChoice = choice;
  document.querySelectorAll('.choice-btn').forEach(b => {
    b.style.color = '#555';
    b.style.borderBottomColor = '#222';
  });
  btn.style.color = '#fff';
  btn.style.borderBottomColor = '#fff';
  checkConfirm();
}

function checkConfirm() {
  const date = document.getElementById('datepicker');
  const btn = document.getElementById('confirm-btn');
  if (date && date.value && selectedChoice) {
    btn.style.opacity = '1';
    btn.style.pointerEvents = 'auto';
    btn.style.borderColor = '#fff';
  }
}

function confirmDate() {
  const date = document.getElementById('datepicker').value;
  const [y, m, d] = date.split('-');
  const months = ['Jan','Fév','Mar','Avr','Mai','Jun','Jul','Aoû','Sep','Oct','Nov','Déc'];
  const formatted = d + ' ' + months[parseInt(m)-1] + ' ' + y;

  // Fade out musique
  const music = document.getElementById('music');
  let vol = music.volume;
  const fadeOut = setInterval(() => {
    if (vol > 0.05) {
      vol -= 0.05;
      music.volume = vol;
    } else {
      music.volume = 0;
      music.pause();
      clearInterval(fadeOut);
    }
  }, 100);

  const appEl2 = document.getElementById("app");
  appEl2.style.cssText = "display:flex;justify-content:center;align-items:center;flex-direction:column;height:100vh;z-index:20;position:relative;text-align:center;padding:40px 20px;";
  document.getElementById('restart').style.display = 'block';
  appEl2.innerHTML = `
    <div class="fade" style="display:flex;flex-direction:column;align-items:center;width:100%;max-width:420px;gap:0;">
      <p style="
        font-family:'Georgia',serif;
        font-size:0.55em;
        letter-spacing:8px;
        text-transform:uppercase;
        color:#555;
        margin:0 0 20px 0;
      ">— Confirmation —</p>

      <div style="width:40px;height:1px;background:#8b0000;margin:0 auto 28px auto;"></div>

      <h1 style="
        font-family:'Georgia',serif;
        font-size:2.6em;
        font-weight:400;
        font-style:italic;
        letter-spacing:4px;
        color:#fff;
        margin:0 0 6px 0;
        line-height:1.1;
      ">${selectedChoice}</h1>

      <p style="
        font-family:'Georgia',serif;
        font-size:0.75em;
        letter-spacing:5px;
        text-transform:uppercase;
        color:#8b0000;
        margin:0 0 30px 0;
      ">${formatted}</p>

      <div style="width:100%;height:1px;background:#1a1a1a;margin-bottom:28px;"></div>

      <p style="
        font-family:'Georgia',serif;
        font-size:0.7em;
        letter-spacing:4px;
        text-transform:uppercase;
        color:#555;
        margin:0;
        font-style:italic;
      ">See you soon, Emel.</p>
    </div>
  `;
}

document.body.addEventListener("click", () => {
  const music = document.getElementById("music");
  music.volume = 0;
  const playPromise = music.play();
  if (playPromise !== undefined) {
    playPromise.then(() => {
      let vol = 0;
      const fade = setInterval(() => {
        if (vol < 0.5) { vol += 0.05; music.volume = vol; }
        else clearInterval(fade);
      }, 200);
    }).catch(err => console.log("Audio error:", err));
  }
  next();
}, { once: true });
</script>
</body>
</html>
